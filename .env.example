# Supabase (required for cloud accounts & sync)
# Dashboard → Project Settings → API → Project URL + anon public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Copy this file to `.env` in the project root, then restart the dev server.
# Also run `supabase/schema.sql` in the Supabase SQL editor.
# Auth → URL Configuration: set Site URL to your app origin (e.g. http://localhost:5173).
